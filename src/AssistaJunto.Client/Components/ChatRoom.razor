@inject IJSRuntime JS
@inject ILogger<ChatRoom> Logger

<div class="chat-wrapper shadow-sm rounded-3 overflow-hidden">
    <div class="chat-header p-3 d-flex align-items-center justify-content-between">
        <h5 class="mb-0 fw-bold text-white">
            <i class="bi bi-chat-dots me-2"></i>CHAT
        </h5>

        <SoundToggleButton IsMuted="IsNotificationMuted"
                           OnToggle="OnToggleNotifications"
                           ActiveText="Som ativo"
                           MutedText="Silenciado"
                           ActiveTitle="Silenciar som de novas mensagens"
                           MutedTitle="Ativar som de novas mensagens" />
    </div>

    @if (IsChatBlocked)
    {
        <div class="chat-block-alert mx-3 mt-3 mb-2">
            <i class="bi bi-shield-exclamation me-2"></i>
            <span>@(string.IsNullOrWhiteSpace(ChatBlockMessage) ? "Chat temporariamente bloqueado por spam." : ChatBlockMessage)</span>
            <strong class="ms-1">(@ChatBlockSecondsRemaining s)</strong>
        </div>
    }

    <div class="chat-messages-area" @ref="_chatContainer">
        @if (Messages == null || !Messages.Any())
        {
            <div class="d-flex align-items-center justify-content-center h-100">
                <p class="text-muted small italic">Nenhuma mensagem ainda...</p>
            </div>
        }
        else
        {
            @foreach (var msg in Messages)
            {
                <div class="message-item p-3">
                    <div class="d-flex align-items-start gap-2">
                            <UserAvatar DisplayName="@msg.UserDisplayName" Size="32" />

                        <div class="message-content flex-grow-1">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span class="fw-bold sender-name">@msg.UserDisplayName</span>
                                <span class="text-muted sent-time">@msg.SentAt.ToLocalTime().ToString("HH:mm")</span>
                            </div>
                            <div class="message-body">
                                @msg.Content
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
    <div class="chat-input-area p-3 border-top">
        <div class="input-group">
            <input type="text"
                   class="form-control chat-input py-2 shadow-none"
                   placeholder="Digite uma mensagem..."
                   @bind="ChatInput"
                   @bind:event="oninput"
                   @onkeydown="HandleKeyDown"
                   disabled="@IsChatBlocked" />
            <button class="btn btn-primary send-btn px-3 fw-bold" type="button" @onclick="SendMessage" disabled="@IsChatBlocked">
                ENVIAR
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter] public List<ChatMessageModel> Messages { get; set; } = new();
    [Parameter] public EventCallback<string> OnSendMessage { get; set; }
    [Parameter] public bool IsChatBlocked { get; set; }
    [Parameter] public int ChatBlockSecondsRemaining { get; set; }
    [Parameter] public string? ChatBlockMessage { get; set; }
    [Parameter] public bool IsNotificationMuted { get; set; }
    [Parameter] public EventCallback OnToggleNotifications { get; set; }

    private string ChatInput { get; set; } = "";
    private ElementReference _chatContainer;
    private int _lastMessageCount = 0;
    private bool _isSending;

    private async Task SendMessage()
    {
        if (_isSending || IsChatBlocked || string.IsNullOrWhiteSpace(ChatInput))
            return;

        _isSending = true;
        try
        {
            var message = ChatInput;
            ChatInput = "";
            await OnSendMessage.InvokeAsync(message);
        }
        finally
        {
            _isSending = false;
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SendMessage();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Messages != null && Messages.Count > _lastMessageCount)
        {
            _lastMessageCount = Messages.Count;
            try
            {
                await JS.InvokeVoidAsync("eval", "const el = document.querySelector('.chat-messages-area'); if(el) el.scrollTop = el.scrollHeight;");
            }
            catch (Exception ex)
            {
                Logger.LogDebug(ex, "Falha ao aplicar auto-scroll do chat.");
            }
        }
    }
}
