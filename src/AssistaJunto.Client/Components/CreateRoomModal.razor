<div class="modal show d-block modal-overlay" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content create-room-modal p-2 rounded-4 shadow-lg">
            <div class="modal-header border-0 pb-0">
                <div class="d-flex align-items-center gap-2">
                    <h4 class="modal-title fw-bold text-white mb-0">Nova Sala</h4>
                    <span class="room-policy-info" tabindex="0" aria-label="Informações sobre limite de salas">
                        <span class="room-policy-icon">i</span>
                        <span class="room-policy-tooltip">Limite de 3 salas por usuário. Salas são removidas automaticamente após 3 minutos de inatividade.</span>
                    </span>
                </div>
                <button type="button" class="btn-close btn-close-white" @onclick="OnClose"></button>
            </div>

            <div class="modal-body p-4">
                @if (Model is not null)
                {
                    <div class="mb-4">
                        <label class="form-label small text-white fw-bold text-uppercase">Nome da Sala</label>
                        <input type="text"
                               class="form-control modal-input text-white py-2"
                               @bind="Model.Name"
                               @bind:event="oninput"
                               placeholder="Ex: Noite de Cinema"
                               autofocus />
                    </div>

                    <div class="mb-3">
                        <label class="form-label small text-white fw-bold text-uppercase">Senha (Opcional)</label>
                        <input type="password"
                               class="form-control modal-input text-white py-2"
                               @bind="Model.Password"
                               @bind:event="oninput"
                               placeholder="••••••••" />
                    </div>
                }
            </div>

            <div class="modal-footer border-0 pt-0 gap-3">
                <button class="btn text-white fw-bold text-decoration-none" @onclick="OnClose">Cancelar</button>
                <button class="btn btn-primary px-4 fw-bold shadow-sm col"
                        @onclick="OnConfirm"
                        disabled="@(string.IsNullOrWhiteSpace(Model?.Name))">
                    CRIAR SALA
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public CreateRoomModel? Model { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnConfirm { get; set; }
}