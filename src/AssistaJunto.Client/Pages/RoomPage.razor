@page "/sala/{RoomHash}"
@using AssistaJunto.Client.Components
@inject ApiService Api
@inject AuthStateService AuthState
@inject RoomHubService Hub
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject ILogger<RoomPage> Logger
@implements IAsyncDisposable

<PageTitle>Sala — Assista Junto</PageTitle>

<div class="position-fixed top-0 end-0 p-3" style="z-index:1080">
    @foreach (var toast in _toasts)
    {
        <div class="custom-toast p-3 mb-2 d-flex align-items-center justify-content-between animate__animated animate__fadeInRight">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-info-circle-fill"></i>
                <span class="fw-medium">@toast.Message</span>
            </div>
            <button type="button" class="btn-close btn-close-white ms-3" @onclick="() => DismissToast(toast.Id)"></button>
        </div>
    }
</div>

@if (_showNamePrompt)
{
    <NamePromptModal OnConfirm="OnNameSubmitted" />
}
else if (_showPasswordModal)
{
    <PasswordModal @bind-Password="_joinPassword"
                   ShowError="_passwordError"
                   OnClose='() => Nav.NavigateTo("/")'
                   OnConfirm="SubmitPassword" />
}
else if (_room is null){
    <div class="d-flex flex-column justify-content-center align-items-center vh-100 bg-black">
        <div class="spinner-border text-primary mb-3"></div>
        <p class="text-muted text-uppercase fw-bold small">Sincronizando com a sala...</p>
    </div>
}
else
{
    <section class="room-shell">
        <div class="container-fluid py-3 py-lg-4">
            <div class="room-grid">
                <div class="room-main-column">
                    <div class="room-main-header mb-3">
                        <div>
                            <p class="room-overline mb-1">SALA ATIVA</p>
                            <h4 class="text-white fw-bold mb-0">@_room.Name</h4>
                        </div>
                        <div class="room-status-pill">
                            <span class="dot"></span>@(_isPlaying ? "Ao vivo" : "Pausado")
                        </div>
                    </div>

                    <div class="player-stage mb-3">
                        <div class="ratio ratio-16x9 rounded-4 overflow-hidden">
                            <div id="yt-player"></div>
                        </div>
                    </div>

                    <VideoControls IsPlaying="_isPlaying"
                                   Volume="_volume"
                                   IsMuted="_isMuted"
                                   OnPlay="OnPlay"
                                   OnPause="OnPause"
                                   OnNext="OnNext"
                                   OnPrevious="OnPrevious"
                                   OnToggleMute="ToggleMute"
                                   OnVolumeChanged="UpdateVolume" />
                </div>

                <aside class="room-side-column">
                    <div class="side-panel add-video-panel">
                        <div class="input-group">
                            <input type="text" class="form-control add-video-input" @bind="_youtubeUrl" placeholder="Cole o link do YouTube ou playlist..." disabled="@_isAddingVideos" />
                            <button class="btn btn-primary add-video-button" @onclick="() => AddVideo(PlaylistInsertModeModel.End)" disabled="@_isAddingVideos">
                                @if (_isAddingVideos)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                    <span>Carregando...</span>
                                }
                                else
                                {
                                    <span>+ Fila</span>
                                }
                            </button>
                        </div>

                        <div class="add-video-actions mt-2">
                            <button class="btn btn-sm btn-outline-info add-action-btn"
                                    title="Adiciona o vídeo logo após o que está tocando"
                                    aria-label="Adiciona o vídeo logo após o que está tocando"
                                    @onclick="() => AddVideo(PlaylistInsertModeModel.AfterCurrent)"
                                    disabled="@_isAddingVideos">
                                <i class="bi bi-skip-forward me-1"></i>Após atual
                            </button>

                            <button class="btn btn-sm btn-outline-warning add-action-btn"
                                    title="Coloca o vídeo para tocar imediatamente"
                                    aria-label="Coloca o vídeo para tocar imediatamente"
                                    @onclick="() => AddVideo(PlaylistInsertModeModel.PlayNow)"
                                    disabled="@_isAddingVideos">
                                <i class="bi bi-play-circle me-1"></i>Ver agora
                            </button>

                            <button class="btn btn-sm add-shuffle-toggle @(_shuffleOnAdd ? "active" : "")"
                                    title="Embaralha a ordem dos vídeos ao adicionar uma playlist"
                                    aria-label="Embaralha a ordem dos vídeos ao adicionar uma playlist"
                                    @onclick="ToggleShuffleOnAdd"
                                    disabled="@_isAddingVideos">
                                <i class="bi bi-shuffle me-1"></i>Shuffle na adição: @(_shuffleOnAdd ? "ON" : "OFF")
                            </button>
                        </div>

                        @if (_isAddingVideos)
                        {
                            <div class="adding-info mt-2" role="alert">
                                <div class="spinner-border spinner-border-sm text-info me-2"></div>
                                <small>Buscando vídeo(s) no YouTube, aguarde...</small>
                            </div>
                        }
                    </div>

                    <div class="side-panel playlist-panel">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h5 class="text-white fw-bold mb-0"><i class="bi bi-music-note-list me-2"></i>Playlist (@_playlist.Count vídeos)</h5>

                            <div class="playlist-actions">
                                @if (_playlist.Count > 1)
                                {
                                    <button class="btn btn-outline-info btn-sm" @onclick="ShufflePlaylistNow" disabled="@_isShufflingPlaylist" title="Embaralhar próximos vídeos">
                                        @if (_isShufflingPlaylist)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1"></span>
                                            <span>Embaralhando</span>
                                        }
                                        else
                                        {
                                            <span><i class="bi bi-shuffle me-1"></i>Embaralhar</span>
                                        }
                                    </button>
                                }

                                @if (_playlist.Count > 0)
                                {
                                    <button class="btn btn-outline-danger btn-sm" @onclick="ClearPlaylist" title="Limpar playlist">
                                        🗑 Limpar
                                    </button>
                                }
                            </div>
                        </div>
                        <div class="playlist-scroll">
                            @for (int i = 0; i < _playlist.Count; i++)
                            {
                                var idx = i;
                                var item = _playlist[i];
                                <button type="button"
                                        class="playlist-item d-flex align-items-center @(i == _currentVideoIndex ? "active" : "") @(_dragOverPlaylistIndex == idx ? "drop-target" : "") @(_draggedPlaylistItemId == item.Id ? "dragging-source" : "")"
                                        @onclick="() => OnPlaylistItemClick(idx)"
                                        @ondragover="() => OnPlaylistDragOver(idx)"
                                        @ondragover:preventDefault="true"
                                        @ondrop="() => OnPlaylistDrop(idx)"
                                        @ondrop:preventDefault="true">
                                    <button type="button"
                                            class="drag-handle me-2"
                                            title="Arraste para reordenar"
                                            aria-label="Arrastar para reordenar"
                                            draggable="true"
                                            @ondragstart="() => OnPlaylistDragStart(item.Id)"
                                            @ondragend="OnPlaylistDragEnd"
                                            @onclick:stopPropagation="true">
                                        <i class="bi bi-grip-vertical drag-handle-icon" aria-hidden="true"></i>
                                    </button>
                                    <img src="@item.ThumbnailUrl" alt="" width="88" class="playlist-thumb me-3" />
                                    <div class="flex-grow-1 text-start">
                                        <strong>@item.Title</strong>
                                        <br /><small class="@(i == _currentVideoIndex ? "" : "text-muted")">Adicionado por @item.AddedByDisplayName</small>
                                    </div>
                                    <span class="btn btn-sm btn-outline-danger ms-2" @onclick="() => RemoveVideo(item.Id)" @onclick:stopPropagation="true">✕</span>
                                </button>
                            }
                        </div>
                    </div>

                    <div class="side-panel social-panel">
                        <div class="social-tabs mb-3">
                            <button class="social-tab-btn @(_activeSocialTab == SocialTab.Chat ? "active" : "")" @onclick="() => _activeSocialTab = SocialTab.Chat">
                                <i class="bi bi-chat-dots-fill me-2"></i>Chat
                            </button>
                            <button class="social-tab-btn @(_activeSocialTab == SocialTab.Users ? "active" : "")" @onclick="() => _activeSocialTab = SocialTab.Users">
                                <i class="bi bi-people-fill me-2"></i>Usuários
                                <span class="tab-counter">@_roomUsers.Count</span>
                            </button>
                        </div>

                        @if (_activeSocialTab == SocialTab.Chat)
                        {
                            <div class="chat-panel">
                                <ChatRoom Messages="_chatMessages"
                                          OnSendMessage="HandleSendMessage"
                                          IsChatBlocked="IsChatBlocked"
                                          ChatBlockSecondsRemaining="ChatBlockSecondsRemaining"
                                          ChatBlockMessage="@_chatBlockMessage"
                                          IsNotificationMuted="_isChatNotificationMuted"
                                          OnToggleNotifications="ToggleChatNotificationMute" />
                            </div>
                        }
                        else
                        {
                            <div class="users-tab-panel">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h5 class="text-white fw-bold mb-0">Pessoas na sala</h5>
                                    <span class="room-users-count">@_roomUsers.Count online</span>
                                </div>

                                <UserList Users="_roomUsers" RoomOwner="@_room.OwnerDisplayName" />
                                @if (_roomUsers.Count == 0)
                                {
                                    <span class="text-muted small">Nenhum usuário na sala.</span>
                                }
                            </div>
                        }
                    </div>
                </aside>
            </div>
        </div>
    </section>
}

@code {
    [Parameter] public string RoomHash { get; set; } = "";

    private RoomModel? _room;
    private List<PlaylistItemModel> _playlist = [];
    private List<ChatMessageModel> _chatMessages = [];
    private List<RoomUserModel> _roomUsers = [];
    private List<ToastNotification> _toasts = [];
    private int _currentVideoIndex;
    private bool _isPlaying;
    private string? _currentVideoId;
    private string _youtubeUrl = "";
    private string _chatInput = "";
    private int _volume = 80;
    private bool _isMuted;
    private bool _playerInitialized;
    private bool _playerReady;
    private bool _isAddingVideos;
    private bool _isShufflingPlaylist;
    private bool _shuffleOnAdd;
    private bool _showNamePrompt;
    private bool _showPasswordModal;
    private bool _passwordError;
    private string? _joinPassword;
    private RoomModel? _pendingRoom;
    private Guid? _draggedPlaylistItemId;
    private int? _dragOverPlaylistIndex;
    private bool _isReorderingPlaylist;
    private DateTime _lastPlaylistDropAtUtc = DateTime.MinValue;
    private DotNetObjectReference<RoomPage>? _dotNetRef;
    private ElementReference _chatContainer;
    private SocialTab _activeSocialTab = SocialTab.Chat;
    private double _currentPlaybackTime;
    private CancellationTokenSource? _progressSyncCts;
    private readonly List<DateTime> _localChatSentAtUtc = [];
    private DateTime? _chatBlockedUntilUtc;
    private string? _chatBlockMessage;
    private CancellationTokenSource? _chatBlockCountdownCts;
    private bool _isChatNotificationMuted;

    private DateTime _lastRemoteActionTime = DateTime.MinValue;
    private const int RemoteCooldownMs = 1500;
    private const int ProgressSyncIntervalMs = 3000;
    private const int ChatBurstLimit = 3;
    private const int ChatWindowSeconds = 20;
    private const int ChatBlockSeconds = 60;
    private bool IsRemoteCooldown => (DateTime.UtcNow - _lastRemoteActionTime).TotalMilliseconds < RemoteCooldownMs;
    private bool IsChatBlocked => _chatBlockedUntilUtc.HasValue && _chatBlockedUntilUtc.Value > DateTime.UtcNow;
    private int ChatBlockSecondsRemaining => !IsChatBlocked
        ? 0
        : Math.Max(1, (int)Math.Ceiling((_chatBlockedUntilUtc!.Value - DateTime.UtcNow).TotalSeconds));

    protected override async Task OnInitializedAsync()
    {
        await AuthState.InitializeAsync();

        if (!AuthState.IsAuthenticated)
        {
            _showNamePrompt = true;
            return;
        }

        await JoinRoomAsync();
    }

    private async Task OnNameSubmitted(string name)
    {
        try
        {
            await AuthState.SetUsernameAsync(name);
            _showNamePrompt = false;
            await JoinRoomAsync();
        }
        catch (InvalidOperationException ex)
        {
            ShowToast(ex.Message);
        }
    }

    private async Task JoinRoomAsync()
    {
        var room = await Api.GetRoomAsync(RoomHash);
        if (room is null)
        {
            Nav.NavigateTo("/");
            return;
        }

        var isOwner = string.Equals(room.OwnerDisplayName, AuthState.Username, StringComparison.OrdinalIgnoreCase);
        if (room.HasPassword && !isOwner)
        {
            _pendingRoom = room;
            _showPasswordModal = true;
            _passwordError = false;
            _joinPassword = null;
            return;
        }

        await CompleteRoomJoinAsync(room);
    }

    private async Task CompleteRoomJoinAsync(RoomModel room, RoomStateModel? state = null)
    {
        _room = room;
        _playlist = state?.Playlist ?? room.Playlist;
        _currentVideoIndex = state?.CurrentVideoIndex ?? room.CurrentVideoIndex;
        _isPlaying = state?.IsPlaying ?? room.IsPlaying;
        _currentPlaybackTime = state?.CurrentTime ?? room.CurrentTime;

        Hub.OnRoomStateReceived += OnRoomState;
        Hub.OnPlayerActionReceived += OnPlayerAction;
        Hub.OnChatHistoryReceived += OnChatHistory;
        Hub.OnChatMessageReceived += OnChatMessage;
        Hub.OnPlaylistUpdated += OnPlaylistItem;
        Hub.OnPlaylistCleared += OnPlaylistCleared;
        Hub.OnUserJoined += OnUserJoined;
        Hub.OnUserLeft += OnUserLeft;
        Hub.OnUserListReceived += OnUserListReceived;
        Hub.OnChatBlocked += OnChatBlocked;

        await Hub.ConnectAsync();
        await Hub.JoinRoomAsync(RoomHash);
        StartProgressSync();
    }

    private async Task SubmitPassword()
    {
        if (_pendingRoom is null)
            return;

        var state = await Api.JoinRoomAsync(_pendingRoom.Hash, _joinPassword);
        if (state is null)
        {
            _passwordError = true;
            return;
        }

        _showPasswordModal = false;
        _passwordError = false;

        var room = _pendingRoom;
        _pendingRoom = null;
        await CompleteRoomJoinAsync(room, state);
    }

    private async Task HandleSendMessage(string message)
    {
        if (!TryApplyLocalChatThrottle())
            return;

        await Hub.SendChatMessageAsync(RoomHash, message);
    }

    private bool TryApplyLocalChatThrottle()
    {
        if (IsChatBlocked)
            return false;

        var now = DateTime.UtcNow;
        var windowStart = now.AddSeconds(-ChatWindowSeconds);
        _localChatSentAtUtc.RemoveAll(t => t < windowStart);

        if (_localChatSentAtUtc.Count >= ChatBurstLimit)
        {
            ActivateChatBlock(ChatBlockSeconds, "Muitas mensagens seguidas. Aguarde para enviar novamente.");
            return false;
        }

        _localChatSentAtUtc.Add(now);
        return true;
    }

    private void OnChatBlocked(int secondsRemaining, string message)
    {
        InvokeAsync(() =>
        {
            ActivateChatBlock(secondsRemaining, message);
            StateHasChanged();
        });
    }

    private void ActivateChatBlock(int secondsRemaining, string? message)
    {
        _chatBlockedUntilUtc = DateTime.UtcNow.AddSeconds(Math.Max(1, secondsRemaining));
        _chatBlockMessage = string.IsNullOrWhiteSpace(message)
            ? "Chat temporariamente bloqueado por spam."
            : message;

        _localChatSentAtUtc.Clear();
        StartChatBlockCountdown();
    }

    private void StartChatBlockCountdown()
    {
        _chatBlockCountdownCts?.Cancel();
        _chatBlockCountdownCts?.Dispose();

        _chatBlockCountdownCts = new CancellationTokenSource();
        _ = RunChatBlockCountdownAsync(_chatBlockCountdownCts.Token);
    }

    private async Task RunChatBlockCountdownAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (!cancellationToken.IsCancellationRequested && IsChatBlocked)
            {
                await Task.Delay(1000, cancellationToken);
                await InvokeAsync(StateHasChanged);
            }

            if (!cancellationToken.IsCancellationRequested)
            {
                _chatBlockedUntilUtc = null;
                _chatBlockMessage = null;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException ex)
        {
            Logger.LogDebug(ex, "Contagem regressiva de bloqueio do chat foi cancelada para a sala {RoomHash}.", RoomHash);
        }
    }

    private async Task UpdateVolume(int newVolume)
    {
        _volume = newVolume;
        await OnVolumeChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_room is not null && !_playerInitialized)
        {
            _playerInitialized = true;
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("youtubePlayer.initialize", "yt-player", _dotNetRef);
            await JS.InvokeVoidAsync("youtubePlayer.setVolume", _volume);
        }
    }

    [JSInvokable]
    public async Task OnPlayerReady()
    {
        _playerReady = true;
        _lastRemoteActionTime = DateTime.UtcNow;

        if (_playlist.Count > 0 && _currentVideoIndex < _playlist.Count)
        {
            _currentVideoId = _playlist[_currentVideoIndex].VideoId;
            var startTime = _currentPlaybackTime > 0 ? _currentPlaybackTime : 0;

            if (_isPlaying)
                await JS.InvokeVoidAsync("youtubePlayer.loadVideo", _currentVideoId, startTime);
            else
                await JS.InvokeVoidAsync("youtubePlayer.cueVideo", _currentVideoId, startTime);
        }
    }

    [JSInvokable]
    public async Task OnPlayerStateChanged(int state)
    {
        switch (state)
        {
            case 0:
                _isPlaying = false;
                if (_currentVideoIndex < _playlist.Count - 1)
                    await OnNext();
                break;

            case 1:
                _isPlaying = true;
                if (!IsRemoteCooldown)
                {
                    var time = await JS.InvokeAsync<double>("youtubePlayer.getCurrentTime");
                    _currentPlaybackTime = time;
                    await Hub.SendPlayerActionAsync(RoomHash, new PlayerActionModel { Action = 0, SeekTime = time, ExpectedIndex = _currentVideoIndex });
                }
                break;

            case 2:
                _isPlaying = false;
                if (!IsRemoteCooldown)
                {
                    var time = await JS.InvokeAsync<double>("youtubePlayer.getCurrentTime");
                    _currentPlaybackTime = time;
                    await Hub.SendPlayerActionAsync(RoomHash, new PlayerActionModel { Action = 1, SeekTime = time, ExpectedIndex = _currentVideoIndex });
                }
                break;
        }

        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnPlayerSeeked(double seekTime)
    {
        _currentPlaybackTime = seekTime;
        if (!IsRemoteCooldown)
        {
            await Hub.SendPlayerActionAsync(RoomHash, new PlayerActionModel { Action = 2, SeekTime = seekTime, ExpectedIndex = _currentVideoIndex });
        }
    }

    private async Task OnPlay()
    {
        if (_playerReady && _currentPlaybackTime > 0)
        {
            var localTime = await JS.InvokeAsync<double>("youtubePlayer.getCurrentTime");
            if (Math.Abs(localTime - _currentPlaybackTime) > 1.5)
                await JS.InvokeVoidAsync("youtubePlayer.seekTo", _currentPlaybackTime);
        }

        await JS.InvokeVoidAsync("youtubePlayer.play");
    }

    private async Task OnPause()
    {
        await JS.InvokeVoidAsync("youtubePlayer.pause");
    }

    private async Task OnNext()
    {
        await Hub.SendPlayerActionAsync(RoomHash, new PlayerActionModel { Action = 4, ExpectedIndex = _currentVideoIndex });
        await Hub.SyncStateAsync(RoomHash);
    }

    private async Task OnPrevious()
    {
        await Hub.SendPlayerActionAsync(RoomHash, new PlayerActionModel { Action = 5, ExpectedIndex = _currentVideoIndex });
        await Hub.SyncStateAsync(RoomHash);
    }

    private async Task JumpToVideo(int index)
    {
        if (index == _currentVideoIndex) return;
        await Hub.JumpToVideoAsync(RoomHash, index);
    }

    private async Task OnPlaylistItemClick(int index)
    {
        if ((DateTime.UtcNow - _lastPlaylistDropAtUtc).TotalMilliseconds < 250)
        {
            return;
        }

        await JumpToVideo(index);
    }

    private void OnRoomState(RoomStateModel state)
    {
        InvokeAsync(async () =>
        {
            _lastRemoteActionTime = DateTime.UtcNow;
            _currentVideoIndex = state.CurrentVideoIndex;
            _isPlaying = state.IsPlaying;
            _currentPlaybackTime = state.CurrentTime;
            _playlist = state.Playlist;

            if (_playerReady && state.VideoId is not null)
            {
                var startTime = state.CurrentTime > 0 ? state.CurrentTime : 0;

                if (_currentVideoId != state.VideoId)
                {
                    _currentVideoId = state.VideoId;
                    if (state.IsPlaying)
                        await JS.InvokeVoidAsync("youtubePlayer.loadVideo", _currentVideoId, startTime);
                    else
                        await JS.InvokeVoidAsync("youtubePlayer.cueVideo", _currentVideoId, startTime);
                }
                else
                {
                    if (startTime > 0)
                        await JS.InvokeVoidAsync("youtubePlayer.seekTo", startTime);

                    if (state.IsPlaying)
                        await JS.InvokeVoidAsync("youtubePlayer.play");
                    else
                        await JS.InvokeVoidAsync("youtubePlayer.pause");
                }
            }

            _currentVideoId = state.VideoId;
            StateHasChanged();
        });
    }

    private void OnPlayerAction(PlayerActionModel action)
    {
        InvokeAsync(async () =>
        {
            _lastRemoteActionTime = DateTime.UtcNow;

            switch (action.Action)
            {
                case 0:
                    _isPlaying = true;
                    if (action.SeekTime.HasValue)
                    {
                        _currentPlaybackTime = action.SeekTime.Value;
                        await JS.InvokeVoidAsync("youtubePlayer.seekTo", action.SeekTime.Value);
                    }
                    await JS.InvokeVoidAsync("youtubePlayer.play");
                    break;
                case 1:
                    _isPlaying = false;
                    if (action.SeekTime.HasValue)
                    {
                        _currentPlaybackTime = action.SeekTime.Value;
                        await JS.InvokeVoidAsync("youtubePlayer.seekTo", action.SeekTime.Value);
                    }
                    await JS.InvokeVoidAsync("youtubePlayer.pause");
                    break;
                case 2:
                    if (action.SeekTime.HasValue)
                    {
                        _currentPlaybackTime = action.SeekTime.Value;
                        await JS.InvokeVoidAsync("youtubePlayer.seekTo", action.SeekTime.Value);
                    }
                    break;
                case 4:
                case 5:
                    await Hub.SyncStateAsync(RoomHash);
                    break;
            }

            StateHasChanged();
        });
    }

    private void OnChatHistory(List<ChatMessageModel> messages)
    {
        InvokeAsync(() =>
        {
            messages ??= [];

            var merged = _chatMessages
                .Concat(messages)
                .GroupBy(m => m.Id)
                .Select(g => g.First())
                .OrderBy(m => m.SentAt)
                .ToList();

            _chatMessages = merged;
            StateHasChanged();
        });
    }

    private void OnChatMessage(ChatMessageModel message)
    {
        InvokeAsync(async () =>
        {
            if (_chatMessages.Any(m => m.Id == message.Id))
            {
                return;
            }

            _chatMessages.Add(message);

            if (ShouldPlayChatNotification(message))
            {
                await PlayChatNotificationAsync();
            }

            StateHasChanged();
        });
    }

    private async Task ToggleChatNotificationMute()
    {
        _isChatNotificationMuted = !_isChatNotificationMuted;
        await InvokeAsync(StateHasChanged);
    }

    private bool ShouldPlayChatNotification(ChatMessageModel message)
    {
        if (_isChatNotificationMuted)
            return false;

        return !string.Equals(message.UserDisplayName, AuthState.Username, StringComparison.OrdinalIgnoreCase);
    }

    private async Task PlayChatNotificationAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("chatNotifications.playMessageAlert");
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Não foi possível tocar o som de notificação de chat na sala {RoomHash}.", RoomHash);
        }
    }

    private void OnPlaylistItem(PlaylistItemModel item)
    {
        InvokeAsync(async () =>
        {
            var wasEmpty = _playlist.Count == 0;
            _playlist.Add(item);

            if (wasEmpty && _playerReady)
            {
                _lastRemoteActionTime = DateTime.UtcNow;
                _currentVideoIndex = 0;
                _currentVideoId = item.VideoId;
                await JS.InvokeVoidAsync("youtubePlayer.loadVideo", item.VideoId, 0);
            }

            StateHasChanged();
        });
    }

    private void OnPlaylistCleared()
    {
        InvokeAsync(async () =>
        {
            _playlist.Clear();
            _currentVideoIndex = 0;
            _currentPlaybackTime = 0;
            _currentVideoId = null;
            _isPlaying = false;

            if (_playerReady)
                await JS.InvokeVoidAsync("youtubePlayer.stop");

            StateHasChanged();
        });
    }

    private async Task ClearPlaylist()
    {
        await Api.ClearPlaylistAsync(RoomHash);
    }

    private void OnUserJoined(RoomUserModel user)
    {
        InvokeAsync(async () =>
        {
            ShowToast($"{user.DisplayName} entrou na sala");
            StateHasChanged();
        });
    }

    private void OnUserLeft(string userName)
    {
        InvokeAsync(() =>
        {
            ShowToast($"{userName} saiu da sala");
            StateHasChanged();
        });
    }

    private void OnUserListReceived(List<RoomUserModel> users)
    {
        InvokeAsync(() =>
        {
            _roomUsers = users;
            StateHasChanged();
        });
    }

    private void ShowToast(string message)
    {
        var toast = new ToastNotification { Message = message };
        _toasts.Add(toast);
        _ = RemoveToastAfterDelay(toast.Id);
    }

    private async Task RemoveToastAfterDelay(Guid toastId)
    {
        await Task.Delay(4000);
        await InvokeAsync(() =>
        {
            _toasts.RemoveAll(t => t.Id == toastId);
            StateHasChanged();
        });
    }

    private void DismissToast(Guid toastId)
    {
        _toasts.RemoveAll(t => t.Id == toastId);
    }

    private async Task OnVolumeChanged()
    {
        await JS.InvokeVoidAsync("youtubePlayer.setVolume", _volume);
    }

    private async Task ToggleMute()
    {
        _isMuted = !_isMuted;
        if (_isMuted)
            await JS.InvokeVoidAsync("youtubePlayer.mute");
        else
            await JS.InvokeVoidAsync("youtubePlayer.unmute");
    }

    private void ToggleShuffleOnAdd()
    {
        _shuffleOnAdd = !_shuffleOnAdd;
    }

    private async Task AddVideo(PlaylistInsertModeModel insertMode)
    {
        if (string.IsNullOrWhiteSpace(_youtubeUrl)) return;

        _isAddingVideos = true;
        StateHasChanged();

        try
        {
            await Api.AddPlaylistByUrlAsync(RoomHash, new AddPlaylistByUrlRequestModel
            {
                Url = _youtubeUrl.Trim(),
                Shuffle = _shuffleOnAdd,
                InsertMode = insertMode
            });

            _youtubeUrl = "";
        }
        catch (Exception)
        {
            ShowToast("Não foi possível adicionar o vídeo. Verifique o link e tente novamente.");
        }
        finally
        {
            _isAddingVideos = false;
            StateHasChanged();
        }
    }

    private async Task ShufflePlaylistNow()
    {
        if (_playlist.Count <= 1 || _isShufflingPlaylist)
            return;

        _isShufflingPlaylist = true;
        StateHasChanged();

        try
        {
            await Api.ShufflePlaylistAsync(RoomHash);
        }
        catch (Exception)
        {
            ShowToast("Não foi possível embaralhar a playlist agora.");
        }
        finally
        {
            _isShufflingPlaylist = false;
            StateHasChanged();
        }
    }

    private void OnPlaylistDragStart(Guid itemId)
    {
        _draggedPlaylistItemId = itemId;
        _dragOverPlaylistIndex = null;
    }

    private void OnPlaylistDragOver(int targetIndex)
    {
        if (!_draggedPlaylistItemId.HasValue || _dragOverPlaylistIndex == targetIndex)
            return;

        _dragOverPlaylistIndex = targetIndex;
    }

    private void OnPlaylistDragEnd()
    {
        _draggedPlaylistItemId = null;
        _dragOverPlaylistIndex = null;
    }

    private async Task OnPlaylistDrop(int targetIndex)
    {
        if (!_draggedPlaylistItemId.HasValue || _isReorderingPlaylist)
        {
            OnPlaylistDragEnd();
            return;
        }

        var draggedItemId = _draggedPlaylistItemId.Value;
        var sourceIndex = _playlist.FindIndex(x => x.Id == draggedItemId);
        if (sourceIndex < 0 || sourceIndex == targetIndex)
        {
            OnPlaylistDragEnd();
            return;
        }

        var previousPlaylist = _playlist.ToList();
        var previousCurrentVideoIndex = _currentVideoIndex;

        _isReorderingPlaylist = true;
        _lastPlaylistDropAtUtc = DateTime.UtcNow;

        ApplyLocalPlaylistReorder(sourceIndex, targetIndex);
        var optimisticOrder = _playlist.Select(x => x.Id).ToList();
        StateHasChanged();

        try
        {
            await Api.ReorderPlaylistItemAsync(RoomHash, draggedItemId, targetIndex);
        }
        catch (Exception)
        {
            if (IsPlaylistOrder(_playlist, optimisticOrder))
            {
                _playlist = previousPlaylist;
                _currentVideoIndex = ClampPlaylistIndex(previousCurrentVideoIndex);
            }

            ShowToast("Não foi possível reordenar a playlist agora.");
        }
        finally
        {
            _isReorderingPlaylist = false;
            OnPlaylistDragEnd();
            StateHasChanged();
        }
    }

    private void ApplyLocalPlaylistReorder(int sourceIndex, int targetIndex)
    {
        var currentItemId = TryGetCurrentPlaylistItemId();
        var movedItem = _playlist[sourceIndex];

        _playlist.RemoveAt(sourceIndex);
        targetIndex = Math.Clamp(targetIndex, 0, _playlist.Count);
        _playlist.Insert(targetIndex, movedItem);

        if (currentItemId.HasValue)
        {
            var updatedCurrentIndex = _playlist.FindIndex(x => x.Id == currentItemId.Value);
            _currentVideoIndex = updatedCurrentIndex >= 0
                ? updatedCurrentIndex
                : ClampPlaylistIndex(_currentVideoIndex);
        }
        else
        {
            _currentVideoIndex = ClampPlaylistIndex(_currentVideoIndex);
        }
    }

    private Guid? TryGetCurrentPlaylistItemId()
    {
        if (_currentVideoIndex < 0 || _currentVideoIndex >= _playlist.Count)
            return null;

        return _playlist[_currentVideoIndex].Id;
    }

    private int ClampPlaylistIndex(int index)
    {
        if (_playlist.Count == 0)
            return 0;

        return Math.Clamp(index, 0, _playlist.Count - 1);
    }

    private static bool IsPlaylistOrder(List<PlaylistItemModel> playlist, IReadOnlyList<Guid> expectedOrder)
    {
        if (playlist.Count != expectedOrder.Count)
            return false;

        for (var i = 0; i < playlist.Count; i++)
        {
            if (playlist[i].Id != expectedOrder[i])
                return false;
        }

        return true;
    }

    private async Task RemoveVideo(Guid itemId)
    {
        await Api.RemoveFromPlaylistAsync(RoomHash, itemId);
    }

    private async Task SendChat()
    {
        if (string.IsNullOrWhiteSpace(_chatInput)) return;
        await Hub.SendChatMessageAsync(RoomHash, _chatInput);
        _chatInput = "";
    }

    private async Task OnChatKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await SendChat();
    }

    public async ValueTask DisposeAsync()
    {
        _progressSyncCts?.Cancel();
        _progressSyncCts?.Dispose();
        _progressSyncCts = null;

        Hub.OnRoomStateReceived -= OnRoomState;
        Hub.OnPlayerActionReceived -= OnPlayerAction;
        Hub.OnChatHistoryReceived -= OnChatHistory;
        Hub.OnChatMessageReceived -= OnChatMessage;
        Hub.OnPlaylistUpdated -= OnPlaylistItem;
        Hub.OnPlaylistCleared -= OnPlaylistCleared;
        Hub.OnUserJoined -= OnUserJoined;
        Hub.OnUserLeft -= OnUserLeft;
        Hub.OnUserListReceived -= OnUserListReceived;
        Hub.OnChatBlocked -= OnChatBlocked;

        _chatBlockCountdownCts?.Cancel();
        _chatBlockCountdownCts?.Dispose();
        _chatBlockCountdownCts = null;

        await Hub.LeaveRoomAsync(RoomHash);

        if (_playerInitialized)
            await JS.InvokeVoidAsync("youtubePlayer.destroy");

        _dotNetRef?.Dispose();
    }

    private void StartProgressSync()
    {
        _progressSyncCts?.Cancel();
        _progressSyncCts?.Dispose();

        _progressSyncCts = new CancellationTokenSource();
        _ = RunProgressSyncLoopAsync(_progressSyncCts.Token);
    }

    private async Task RunProgressSyncLoopAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (!cancellationToken.IsCancellationRequested)
            {
                await Task.Delay(ProgressSyncIntervalMs, cancellationToken);

                if (!_playerReady || !_isPlaying || _room is null)
                    continue;

                var currentTime = await JS.InvokeAsync<double>("youtubePlayer.getCurrentTime", cancellationToken);
                _currentPlaybackTime = currentTime;
                await Hub.ReportPlaybackProgressAsync(RoomHash, currentTime, _currentVideoIndex);
            }
        }
        catch (OperationCanceledException ex)
        {
            Logger.LogDebug(ex, "Loop de sincronização de progresso foi cancelado para a sala {RoomHash}.", RoomHash);
        }
    }

