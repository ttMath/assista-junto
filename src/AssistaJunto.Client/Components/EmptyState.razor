<div class="empty-state-container text-center py-5 border border-dashed rounded-4 my-5">
    <div class="display-1 mb-4 empty-state-icon">📺</div>
    <h3 class="fw-bold text-white">Nenhuma sala ativa</h3>
    <p class="text-white mb-4 mx-auto empty-state-description">
        O JAÇA CITY está silencioso no momento. Que tal começar uma transmissão agora mesmo?
    </p>
    <button class="btn btn-outline-light empty-state-button px-5 py-2 rounded-pill fw-bold" @onclick="OnCreateClick">
        CRIAR A PRIMEIRA SALA
    </button>
</div>

@code {
    [Parameter] public EventCallback OnCreateClick { get; set; }
}