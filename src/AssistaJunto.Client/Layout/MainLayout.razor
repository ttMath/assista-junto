@inherits LayoutComponentBase
@using AssistaJunto.Client.Components
@inject AuthStateService AuthState
@inject NavigationManager Nav
@implements IDisposable

<div class="page">
    <header class="top-bar d-flex align-items-center justify-content-between px-3 px-md-4 py-2 text-white">
        <div class="d-flex align-items-center gap-3">
            <button @onclick="OnHomeClick" class="text-decoration-none text-white fw-bold fs-5 fs-md-4 home-btn">🎬 Assista Junto</button>
        </div>
        <div class="d-flex align-items-center gap-3">
            @if (AuthState.IsAuthenticated)
            {
                @if (_isEditingName)
                {
                    <div class="d-flex align-items-center gap-2">
                        <input type="text"
                               class="form-control form-control-sm edit-name-input"
                               @bind="_editNameInput"
                               @bind:event="oninput"
                               @onkeydown="OnEditKeyDown"
                               maxlength="50"
                               @ref="_editInput" />
                        <button class="btn btn-sm btn-success px-2 py-0" @onclick="SaveName" disabled="@string.IsNullOrWhiteSpace(_editNameInput)" title="Salvar">
                            ✓
                        </button>
                        <button class="btn btn-sm btn-outline-secondary px-2 py-0" @onclick="CancelEdit" title="Cancelar">
                            ✕
                        </button>
                    </div>
                }
                else
                {
                    <button class="btn btn-sm user-name-btn d-flex align-items-center gap-2" @onclick="StartEdit" title="Clique para alterar o nome">
                        <UserAvatar DisplayName="@AuthState.Username" Size="26" />  
                        <span class="fw-semibold">@AuthState.Username</span>
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                        </svg>
                    </button>
                }
                <button class="btn btn-outline-light btn-sm btn-logout" @onclick="Logout">Sair</button>
            }
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(_editNameError))
    {
        <div class="name-edit-alert">@_editNameError</div>
    }

    @if (_showLeaveRoomModal)
    {
        <div class="modal show d-block modal-overlay" tabindex="-1">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content leave-room-modal p-2 rounded-4 shadow-lg">
                    <div class="modal-header border-0 pb-0">
                        <h4 class="modal-title fw-bold text-white">Sair da sala</h4>
                        <button type="button" class="btn-close btn-close-white" @onclick="CancelLeaveRoom"></button>
                    </div>

                    <div class="modal-body p-4">
                        <p class="text-white mb-0">Deseja sair da sala atual e voltar para a tela inicial?</p>
                    </div>

                    <div class="modal-footer border-0 pt-0 gap-3">
                        <button class="btn text-white fw-bold text-decoration-none" @onclick="ConfirmLeaveRoom">Sim</button>
                        <button class="btn btn-primary px-4 fw-bold shadow-sm col" @onclick="CancelLeaveRoom">Não</button>
                    </div>
                </div>
            </div>
        </div>
    }

    <main class="content-area">
        @Body
    </main>
</div>

@code {
    private bool _isEditingName;
    private string _editNameInput = "";
    private ElementReference _editInput;
    private string? _editNameError;
    private bool _showLeaveRoomModal;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            AuthState.OnAuthStateChanged += OnAuthChanged;
            await AuthState.InitializeAsync();
            StateHasChanged();
        }
    }

    private void OnAuthChanged() => InvokeAsync(StateHasChanged);

    private void StartEdit()
    {
        _editNameInput = AuthState.Username ?? "";
        _editNameError = null;
        _isEditingName = true;
    }

    private void CancelEdit()
    {
        _isEditingName = false;
        _editNameError = null;
    }

    private async Task SaveName()
    {
        if (string.IsNullOrWhiteSpace(_editNameInput)) return;
        try
        {
            await AuthState.SetUsernameAsync(_editNameInput.Trim());
            _editNameError = null;
            _isEditingName = false;
        }
        catch (InvalidOperationException ex)
        {
            _editNameError = ex.Message;
        }
    }

    private async Task OnEditKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SaveName();
        else if (e.Key == "Escape") CancelEdit();
    }

    private async Task Logout()
    {
        await AuthState.LogoutAsync();
        Nav.NavigateTo("/", forceLoad: true);
    }

    private void OnHomeClick()
    {
        if (IsInsideRoom())
        {
            _showLeaveRoomModal = true;
            return;
        }

        Nav.NavigateTo("", true);
    }

    private void CancelLeaveRoom()
    {
        _showLeaveRoomModal = false;
    }

    private void ConfirmLeaveRoom()
    {
        _showLeaveRoomModal = false;
        Nav.NavigateTo("", true);
    }

    private bool IsInsideRoom()
    {
        var relativePath = Nav.ToBaseRelativePath(Nav.Uri);
        var cleanPath = relativePath.Split('?', '#')[0];
        return cleanPath.StartsWith("sala/", StringComparison.OrdinalIgnoreCase);
    }

    public void Dispose()
    {
        AuthState.OnAuthStateChanged -= OnAuthChanged;
    }
}
