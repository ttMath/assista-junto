@page "/"
@using AssistaJunto.Client.Components
@inject AuthStateService AuthState
@inject ApiService Api
@inject NavigationManager Nav

<PageTitle>Assista Junto — JAÇA CITY</PageTitle>

@if (!_initialized)
{
    <div class="d-flex flex-column justify-content-center align-items-center vh-100">
        <div class="custom-loader mb-3"></div>
        <p class="text-white small">SINCRONIZANDO AMBIENTE...</p>
    </div>
}
else if (!AuthState.IsAuthenticated)
{
    <div class="bg-hero d-flex align-items-center justify-content-center">
        <div class="bg-blob blob-1"></div>
        <div class="bg-blob blob-2"></div>

        <div class="container text-center px-4">
            <div class="hero-content-box mx-auto" style="max-width: 800px;">
                <div class="mb-3">
                    <span class="badge rounded-pill bg-dark border border-secondary px-3 py-2 text-uppercase fw-bold mb-4" style="font-size: 0.7rem; letter-spacing: 2px;">
                        🎬 Watch Party Exclusiva
                    </span>
                </div>
                <h1 class="text-glow fw-black mb-2">JAÇA CITY</h1>
                <p class="text-white mb-5 h5 fw-light mx-auto mt-3" style="max-width: 450px;">
                    Assista a vídeos, filmes e séries em sincronia perfeita com sua comunidade.
                </p>

                <div class="d-flex justify-content-center">
                    <div class="d-flex flex-column align-items-center gap-3" style="min-width: 320px;">
                        <input type="text" class="form-control form-control-lg text-center name-entry-input"
                               placeholder="Digite seu nome..."
                               @bind="_nameInput"
                               @onkeydown="OnNameKeyDown"
                               maxlength="30" />
                        <button class="btn btn-lg btn-primary px-5 fw-bold name-entry-button" @onclick="SubmitName" disabled="@string.IsNullOrWhiteSpace(_nameInput)">
                            ENTRAR
                        </button>
                    </div>
                </div>
            </div>

            <div class="mt-5 opacity-25">
                <small class="text-white text-uppercase ls-wider" style="letter-spacing: 5px;">Powered by AMIGOS DO JAÇA</small>
            </div>
        </div>
    </div>
}
else
{
    <section class="lobby-shell">
        <div class="container py-4 py-lg-5">
            <div class="lobby-hero mb-4 mb-lg-5">
                <div>
                    <p class="lobby-eyebrow mb-2">ASSISTA JUNTO</p>
                    <h1 class="fw-black text-white mb-2">Lobby da Comunidade</h1>
                    <p class="text-muted mb-0">Entre em uma sala ativa ou crie uma nova sessão sincronizada.</p>
                </div>
                <button class="btn btn-primary btn-create-room" @onclick="PrepareNewRoom">
                    + Nova Sala
                </button>
            </div>

            @if (_rooms is null)
            {
                <div class="lobby-loading text-center py-5 text-muted">Buscando salas...</div>
            }
            else if (_rooms.Count == 0)
            {
                <EmptyState OnCreateClick="PrepareNewRoom" />
            }
            else
            {
                <div class="row g-4">
                    @foreach (var room in _rooms)
                    {
                        <Roomcard RoomName="@room.Name"
                                  OwnerName="@room.OwnerDisplayName"
                                  IsUserOwner="@(room.OwnerDisplayName == AuthState.Username)"
                                  VideoCount="@room.Playlist.Count"
                                  HasPassword="@room.HasPassword"
                                  OnDelete="() => ConfirmDeleteRoom(room.Hash)"
                                  OnJoin="() => EnterRoom(room)"
                                  Hash="@room.Hash"
                                  UserCount="@room.UsersCount" />
                    }
                </div>
            }
        </div>
    </section>

    @if (_showCreateModal)
    {
        <CreateRoomModal Model="_createModel"
                         OnClose="() => _showCreateModal = false"
                         OnConfirm="CreateRoom" />

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="fixed-bottom p-4 d-flex justify-content-center">
                <div class="alert alert-danger shadow">@_errorMessage</div>
            </div>
        }
    }

    @if (_showPasswordModal)
    {
        <PasswordModal @bind-Password="_joinPassword"
                       ShowError="_passwordError"
                       OnClose="() => _showPasswordModal = false"
                       OnConfirm="SubmitPassword" />
    }
}

@code {
    private List<RoomModel>? _rooms;
    private bool _showCreateModal;
    private bool _showPasswordModal;
    private bool _passwordError;
    private string? _errorMessage;

    private CreateRoomModel _createModel = new();

    private string? _joinPassword;
    private RoomModel? _pendingRoom;
    private string _nameInput = "";
    private bool _initialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await AuthState.InitializeAsync();
            if (AuthState.IsAuthenticated)
            {
                _rooms = await Api.GetActiveRoomsAsync();
            }
            _initialized = true;
            StateHasChanged();
        }
    }

    private async Task SubmitName()
    {
        if (string.IsNullOrWhiteSpace(_nameInput)) return;
        await AuthState.SetUsernameAsync(_nameInput.Trim());
        _rooms = await Api.GetActiveRoomsAsync();
        StateHasChanged();
    }

    private async Task OnNameKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await SubmitName();
    }

    private void PrepareNewRoom()
    {
        _errorMessage = null;
        _createModel = new CreateRoomModel();
        _showCreateModal = true;
    }

    private async Task CreateRoom()
    {
        if (string.IsNullOrWhiteSpace(_createModel.Name)) return;

        try
        {
            _errorMessage = null;

            var room = await Api.CreateRoomAsync(_createModel);

            if (room is not null)
            {
                _showCreateModal = false;
                Nav.NavigateTo($"/sala/{room.Hash}");
            }
        }
        catch (Exception ex)
        {
            _errorMessage = "Erro 500: O servidor rejeitou os dados. Tente outro nome.";
            Console.WriteLine(ex.Message);
        }
    }

    private void EnterRoom(RoomModel room)
    {
        if (room.HasPassword) { _pendingRoom = room; _showPasswordModal = true; }
        else { Nav.NavigateTo($"/sala/{room.Hash}"); }
    }

    private async Task ConfirmDeleteRoom(string hash)
    {
        var success = await Api.DeleteRoomAsync(hash);
        if (success)
        {
            _rooms?.RemoveAll(r => r.Hash == hash);
            StateHasChanged();
        }
    }
    private async Task SubmitPassword()
    {
        if (_pendingRoom is null) return;
        var state = await Api.JoinRoomAsync(_pendingRoom.Hash, _joinPassword);
        if (state is not null) Nav.NavigateTo($"/sala/{_pendingRoom.Hash}");
        else _passwordError = true;
    }
}